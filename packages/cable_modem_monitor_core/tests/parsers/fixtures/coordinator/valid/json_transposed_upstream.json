        {"label": "Center Freq SC0", "field": "frequency",  "type": "frequency", "unit": "MHz"},
        {"label": "rep power",       "field": "power",      "type": "float", "unit": "dBmV"}
      ],
      "filter": {"Power": "ON"}
    }
  },
  "_expected": {
    "downstream": [],
    "upstream": [
      {
        "channel_id": 1,
        "channel_number": 1,
        "channel_type": "ofdma",
        "frequency": 10000000,
        "power": 43.4
      }
    ],
    "system_info": {
      "downstream_channel_count": 0,
      "upstream_channel_count": 1
    }
  }
}
